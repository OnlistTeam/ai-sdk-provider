{
  "name": "@onlist/ai-sdk-provider",
  "version": "0.1.0",
  "description": "Onlist provider for the Vercel AI SDK. Route requests across 40+ AI providers with competitive pricing.",
  "license": "MIT",
  "author": "Onlist <dev@onlist.io>",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.0"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://onlist.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnlistTeam/ai-sdk-provider"
  },
  "bugs": {
    "url": "https://github.com/OnlistTeam/ai-sdk-provider/issues"
  },
  "keywords": [
    "onlist",
    "ai-sdk",
    "vercel-ai",
    "ai",
    "llm",
    "openai",
    "claude",
    "gemini",
    "deepseek",
    "provider",
    "ai-gateway",
    "provider-routing"
  ]
}
